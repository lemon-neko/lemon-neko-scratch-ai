    "---\n",
    "\n",
    "## 第八步：封装成类\n",
    "\n",
    "把所有组件封装成一个干净的类，方便后续扩展。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SelfAttentionFromScratch:\n",
    "    \"\"\"\n",
    "    从头实现的 Self-Attention 模块\n",
    "    \n",
    "    包含:\n",
    "    - Multi-Head Attention\n",
    "    - Layer Normalization (用于残差连接后的归一化)\n",
    "    - Position-wise Feed Forward\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, d_model=512, num_heads=8, d_ff=2048, dropout=0.1):\n",
    "        \"\"\"\n",
    "        Args:\n",
    "            d_model: 模型维度\n",
    "            num_heads: 注意力头数\n",
    "            d_ff: FFN 中间层维度\n",
    "            dropout: Dropout 率\n",
    "        \"\"\"\n",
    "        self.d_model = d_model\n",
    "        self.num_heads = num_heads\n",
    "        self.d_k = d_model // num_heads\n",
    "        self.dropout_rate = dropout\n",
    "        \n",
    "        # 初始化权重（实际项目中会用 Xavier/He 初始化）\n",
    "        scale = 1.0 / np.sqrt(d_model)\n",
    "        self.W_Q = np.random.randn(d_model, d_model) * scale\n",
    "        self.W_K = np.random.randn(d_model, d_model) * scale\n",
    "        self.W_V = np.random.randn(d_model, d_model) * scale\n",
    "        self.W_O = np.random.randn(d_model, d_model) * scale\n",
    "        \n",
    "        # FFN 权重\n",
    "        self.W_1 = np.random.randn(d_model, d_ff) * scale\n",
    "        self.b_1 = np.zeros(d_ff)\n",
    "        self.W_2 = np.random.randn(d_ff, d_model) * scale\n",
    "        self.b_2 = np.zeros(d_model)\n",
    "    \n",
    "    def split_heads(self, x):\n",
    "        batch, seq_len, _ = x.shape\n",
    "        return x.reshape(batch, seq_len, self.num_heads, self.d_k).transpose(0, 2, 1, 3)\n",
    "    \n",
    "    def merge_heads(self, x):\n",
    "        batch, num_heads, seq_len, d_k = x.shape\n",
    "        return x.transpose(0, 2, 1, 3).reshape(batch, seq_len, num_heads * d_k)\n",
    "    \n",
    "    def scaled_dot_product_attention(self, Q, K, V, training=False):\n",
    "        scores = np.matmul(Q, K.transpose(0, 1, 3, 2)) / np.sqrt(self.d_k)\n",
    "        \n",
    "        # Softmax\n",
    "        exp_scores = np.exp(scores - np.max(scores, axis=-1, keepdims=True))\n",
    "        attn_weights = exp_scores / np.sum(exp_scores, axis=-1, keepdims=True)\n",
    "        \n",
    "        # Dropout\n",
    "        if training and self.dropout_rate > 0:\n",
    "            mask = (np.random.rand(*attn_weights.shape) > self.dropout_rate).astype(np.float32)\n",
    "            attn_weights = attn_weights * mask / (1 - self.dropout_rate)\n",
    "        \n",
    "        output = np.matmul(attn_weights, V)\n",
    "        return output, attn_weights\n",
    "    \n",
    "    def layer_norm(self, x, epsilon=1e-6):\n",
    "        \"\"\"Layer Normalization: 对最后一个维度做归一化\"\"\"\n",
    "        mean = np.mean(x, axis=-1, keepdims=True)\n",
    "        std = np.std(x, axis=-1, keepdims=True)\n",
    "        return (x - mean) / (std + epsilon)\n",
    "    \n",
    "    def ff(self, x, training=False):\n",
    "        \"\"\"Position-wise Feed Forward Network\"\"\"\n",
    "        # ReLU 激活\n",
    "        h = np.maximum(0, x @ self.W_1 + self.b_1)\n",
    "        if training and self.dropout_rate > 0:\n",
    "            mask = (np.random.rand(*h.shape) > self.dropout_rate).astype(np.float32)\n",
    "            h = h * mask / (1 - self.dropout_rate)\n",
    "        return h @ self.W_2 + self.b_2\n",
    "    \n",
    "    def forward(self, X, training=False):\n",
    "        \"\"\"\n",
    "        完整的前向传播（带残差连接 + LayerNorm）\n",
    "        \n",
    "        结构:\n",
    "        1. Multi-Head Attention + Residual + LayerNorm\n",
    "        2. FFN + Residual + LayerNorm\n",
    "        \"\"\"\n",
    "        # === Sublayer 1: Multi-Head Attention ===\n",
    "        Q = X @ self.W_Q\n",
    "        K = X @ self.W_K\n",
    "        V = X @ self.W_V\n",
    "        \n",
    "        Q_heads = self.split_heads(Q)\n",
    "        K_heads = self.split_heads(K)\n",
    "        V_heads = self.split_heads(V)\n",
    "        \n",
    "        attn_output, attn_weights = self.scaled_dot_product_attention(\n",
    "            Q_heads, K_heads, V_heads, training=training\n",
    "        )\n",
    "        \n",
    "        attn_concat = self.merge_heads(attn_output)\n",
    "        attn_out = attn_concat @ self.W_O\n",
    "        \n",
    "        # Residual + LayerNorm\n",
    "        h1 = self.layer_norm(X + attn_out)\n",
    "        \n",
    "        # === Sublayer 2: Feed Forward ===\n",
    "        ff_out = self.ff(h1, training=training)\n",
    "        \n",
    "        # Residual + LayerNorm\n",
    "        output = self.layer_norm(h1 + ff_out)\n",\n",
    "        \n",
    "        return output, attn_weights\n",
    "    \n",
    "    def summary(self):\n",
    "        \"\"\"打印模块信息\"\"\"\n",
    "        total_params = (\n",
    "            self.d_model**2 * 4 +  # W_Q, W_K, W_V, W_O\n",
    "            self.d_model * self.d_ff * 2 +  # W_1, W_2\n",
    "            self.d_ff + self.d_model  # b_1, b_2\n",
    "        )\n",
    "        print(f\"\"\"\n",
    "Self-Attention 模块配置:\n",
    "  d_model:    {self.d_model}\n",
    "  num_heads:  {self.num_heads}\n",
    "  d_k:        {self.d_k}\n",
    "  d_ff:       {self.d_ff}\n",
    "  dropout:    {self.dropout_rate}\n",
    "  参数量:     {total_params:,}\n",
    "        \"\"\")\n",
    "\n",
    "# 实例化并测试\n",
    "attention = SelfAttentionFromScratch(d_model=6, num_heads=3, d_ff=12)\n",
    "attention.summary()\n",
    "\n",
    "output, weights = attention.forward(X, training=False)\n",
    "print(f\"输出形状: {output.shape}\")\n",
    "print(f\"输出:\\n{output[0]}\")"
   ]
